# ==============================================================================
# StallManagement — Environment Variable Template
# ==============================================================================
# Copy this file to .env and fill in your actual values.
#
#   cp .env.example .env
#
# NEVER commit .env to version control — it contains secrets.
# This .env.example file is safe to commit (no real credentials).
# ==============================================================================


# ------------------------------------------------------------------------------
# Django Core
# ------------------------------------------------------------------------------

# Generate a new secret key with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=w$8#k2!mxq@v5&nj6*rp3+yz0^tf9%hd4_se7cglu1(boa-iw)

# Set to False in production
DJANGO_DEBUG=True

# Comma-separated list of allowed hostnames (no spaces)
# Example: DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost


# ------------------------------------------------------------------------------
# MySQL 8.0 Database
# ------------------------------------------------------------------------------

DB_NAME=db_market
DB_USER=root
DB_PASSWORD=password
DB_HOST=127.0.0.1
DB_PORT=3306


# ------------------------------------------------------------------------------
# Redis (required for Django Channels WebSocket support)
# ------------------------------------------------------------------------------

# Local Redis (default)
REDIS_URL=redis://127.0.0.1:6379

# Redis with password:
# REDIS_URL=redis://:your_redis_password@127.0.0.1:6379

# Docker Redis:
# REDIS_URL=redis://redis:6379


# ------------------------------------------------------------------------------
# CSRF (Django CSRF trusted origins — required for POST requests from the SPA)
# ------------------------------------------------------------------------------

CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000


# ------------------------------------------------------------------------------
# Optional: Email (for password reset functionality if added later)
# ------------------------------------------------------------------------------

# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your@email.com
# EMAIL_HOST_PASSWORD=your_app_password
